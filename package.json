{
  "name": "payunivercart",
  "version": "0.0.1",
  "private": true,
  "description": "Payment facilitator platform for digital product creators",
  "license": "UNLICENSED",
  "author": "Kennedy Rodrigues <kennedy.rodrigues1104@gmail.com>",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @payunivercart/db generate",
    "db:migrate": "pnpm --filter @payunivercart/db migrate",
    "db:studio": "pnpm --filter @payunivercart/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.9.14",
    "typescript": "5.7.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0",
      "next": "15.5.18",
      "postcss": "^8.5.10",
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "vite": "^6.4.2",
      "vitest": "^3.2.4",
      "better-auth>zod": "^4.3.5",
      "better-call>zod": "^4.3.5",
      "@better-auth/core>zod": "^4.3.5",
      "@better-fetch/fetch>zod": "^4.3.5"
    }
  }
}

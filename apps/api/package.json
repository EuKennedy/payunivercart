{
  "name": "@payunivercart/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "exports": {
    ".": "./src/server.ts",
    "./routers": "./src/routers/index.ts",
    "./trpc": "./src/trpc.ts",
    "./tracking/dispatcher": "./src/tracking/dispatcher.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "2.0.2",
    "@hono/trpc-server": "0.4.2",
    "@payunivercart/audit": "workspace:*",
    "@payunivercart/auth": "workspace:*",
    "@payunivercart/connect": "workspace:*",
    "@payunivercart/crypto": "workspace:*",
    "@payunivercart/db": "workspace:*",
    "@payunivercart/emails": "workspace:*",
    "@payunivercart/payments": "workspace:*",
    "@payunivercart/shared": "workspace:*",
    "@payunivercart/waha": "workspace:*",
    "@sentry/node": "8.51.0",
    "@trpc/server": "11.17.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.18",
    "hono-rate-limiter": "0.5.3",
    "ioredis": "5.4.2",
    "rate-limit-redis": "5.0.0",
    "tsx": "4.19.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "dotenv": "16.4.7",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}

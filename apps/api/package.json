    "@payunivercart/db": "workspace:*",
    "@payunivercart/payments": "workspace:*",
    "@payunivercart/shared": "workspace:*",
    "@payunivercart/waha": "workspace:*",
    "@trpc/server": "11.0.0-rc.802",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.18",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "dotenv": "16.4.7",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"

# =========================================================================
# payunivercart — Environment variables example
# Copy to .env (root) for local Docker Compose. NEVER commit real values.
# -------------------------------------------------------------------------
# Placeholder convention:
#   - `__REPLACE_ME__<NAME>`        — any value the operator must replace
#                                     before the app boots.
#   - The bootstrap validator in `apps/api` (Bloco future) refuses to start
#     if any env var still contains `__REPLACE_ME__`.
# =========================================================================

# ---------- Runtime ----------
NODE_ENV=development
APP_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3000
CHECKOUT_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
API_URL=http://localhost:4000

# ---------- PostgreSQL ----------
POSTGRES_USER=payunivercart
POSTGRES_PASSWORD=__REPLACE_ME__POSTGRES_PASSWORD
POSTGRES_DB=payunivercart
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://payunivercart:__REPLACE_ME__POSTGRES_PASSWORD@postgres:5432/payunivercart

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=__REPLACE_ME__REDIS_PASSWORD
REDIS_URL=redis://default:__REPLACE_ME__REDIS_PASSWORD@redis:6379

# ---------- Auth ----------
# Generate with: openssl rand -hex 32   (≥64 hex chars; the bootstrap
# validator rejects anything shorter or containing `__REPLACE_ME__`).
AUTH_SECRET=__REPLACE_ME__AUTH_SECRET_HEX64
AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
SESSION_COOKIE_DOMAIN=.localhost

# ---------- Email (Resend) ----------
RESEND_API_KEY=__REPLACE_ME__RESEND_API_KEY
EMAIL_FROM="payunivercart <no-reply@univercart.com>"

# ---------- WAHA (WhatsApp HTTP API, web.js engine) ----------
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=__REPLACE_ME__WAHA_API_KEY
WAHA_DEFAULT_SESSION=default
# Generate with: openssl rand -hex 32
WAHA_WEBHOOK_SECRET=__REPLACE_ME__WAHA_WEBHOOK_SECRET

# ---------- Encryption (KEK registry for credentials-at-rest) ----------
# Format: <keyId>:<base64 32-byte key>[,<keyId>:<base64 32-byte key>]...
# Generate one with: openssl rand -base64 32
# Multiple entries enable rotation — keep the old key live until every row
# is re-sealed under the new active keyId.
ENCRYPTION_KEYS=v1:__REPLACE_ME__BASE64_32_BYTE_KEY
ENCRYPTION_ACTIVE_KEY_ID=v1

# ---------- Audit chain (HMAC key for events_audit) ----------
# Independent from ENCRYPTION_KEYS so an audit-key compromise does NOT
# decrypt gateway credentials. Same format and rotation policy.
AUDIT_KEYS=v1:__REPLACE_ME__BASE64_32_BYTE_KEY
AUDIT_ACTIVE_KEY_ID=v1

# ---------- Observability ----------
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---------- Platform billing (workspace subscription R$99,90/mes) ----------
PLATFORM_BILLING_GATEWAY=stripe
PLATFORM_STRIPE_SECRET_KEY=
PLATFORM_STRIPE_WEBHOOK_SECRET=
PLATFORM_WORKSPACE_PRICE_BRL=99.90

# =========================================================================
# payunivercart — Environment variables example
# Copy to .env (root) for local Docker Compose, never commit real values
# =========================================================================

# ---------- Runtime ----------
NODE_ENV=development
APP_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3000
CHECKOUT_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
API_URL=http://localhost:4000

# ---------- PostgreSQL ----------
POSTGRES_USER=payunivercart
POSTGRES_PASSWORD=replace_me_strong_password
POSTGRES_DB=payunivercart
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://payunivercart:replace_me_strong_password@postgres:5432/payunivercart

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace_me_redis_password
REDIS_URL=redis://default:replace_me_redis_password@redis:6379

# ---------- Auth ----------
AUTH_SECRET=generate_with_openssl_rand_hex_32
AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
SESSION_COOKIE_DOMAIN=.localhost

# ---------- Email (Resend) ----------
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM="payunivercart <no-reply@univercart.com>"

# ---------- WAHA (WhatsApp HTTP API, web.js engine) ----------
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=replace_me_waha_api_key
WAHA_DEFAULT_SESSION=default
WAHA_WEBHOOK_SECRET=replace_me_webhook_secret

# ---------- Encryption (KMS-equivalent for gateway credentials) ----------
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# ---------- Observability ----------
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---------- Platform billing (workspace subscription R$99,90/mes) ----------
PLATFORM_BILLING_GATEWAY=stripe
PLATFORM_STRIPE_SECRET_KEY=
PLATFORM_STRIPE_WEBHOOK_SECRET=
PLATFORM_WORKSPACE_PRICE_BRL=99.90

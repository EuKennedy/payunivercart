auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
prefer-workspace-packages=true
link-workspace-packages=true
save-exact=true
engine-strict=true

# Hoist React + React DOM + Next + Tailwind to the top-level node_modules.
# pnpm's strict isolation creates situations where webpack ends up with
# two copies of React (one from the app, one from `transpilePackages`'
# workspace deps' resolution), and React 19's stricter context checks
# explode with `TypeError: Cannot read properties of null (reading
# 'useContext')` during `next build`'s prerender of `/_global-error`.
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*react-dom*
public-hoist-pattern[]=next
public-hoist-pattern[]=tailwindcss
public-hoist-pattern[]=@tailwindcss/*
